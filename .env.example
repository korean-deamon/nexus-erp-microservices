# --- Database Configuration ---
POSTGRES_USER=admin
POSTGRES_PASSWORD=password
POSTGRES_DB=nexus_erp
# URL used by Prisma and other services
DATABASE_URL="postgresql://admin:password@postgres:5432/nexus_erp?schema=operations"

# --- Security ---
JWT_SECRET="your-secure-secret-key-here"

# --- Service Networking ---
SERVICE_B_URL="http://service-analytics:8000"

# --- Frontend (Client-side) ---
# Should point to the Nginx Gateway for production/local access
NEXT_PUBLIC_API_URL="http://localhost:8080/api/v1"
NEXT_PUBLIC_WS_URL="ws://localhost:8080"
